# HTTP port (application.yaml server.port). Project-root .env is loaded at startup by the app.
APP_PORT=8080
DB_PORT=5432
POSTGRES_DB=hrd_room_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Keep security off for local compose unless Keycloak is wired
APP_SECURITY_ENABLED=false

# Keycloak (required only when APP_SECURITY_ENABLED=true)
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/assessment
KEYCLOAK_JWK_SET_URI=http://localhost:8080/realms/assessment/protocol/openid-connect/certs
JWT_PRINCIPAL_CLAIM=sub
KEYCLOAK_AUTH_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=assessment
KEYCLOAK_CLIENT_ID=hrd-room-service
KEYCLOAK_CLIENT_SECRET=change-me

# RustFS / S3-compatible storage (optional)
RUSTFS_ENABLED=true
RUSTFS_IMAGE=rustfs/rustfs:latest
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001
RUSTFS_ENDPOINT_URL=http://rustfs:9000
# Public URL used in API responses (set localhost, domain, or reverse-proxy URL)
RUSTFS_PUBLIC_ENDPOINT_URL=http://localhost:9000
RUSTFS_BUCKET_NAME=hrd-room-service
RUSTFS_ACCESS_KEY_ID=rustfsadmin
RUSTFS_SECRET_ACCESS_KEY=rustfsadmin
RUSTFS_REGION=us-east-1
